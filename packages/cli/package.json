{
  "$schema": "https://json.schemastore.org/package.json",
  "version": "1.0.0",
  "name": "@liteai/cli",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "bun run --conditions=browser ./src/index.ts",
    "dev:serve": "bun --watch run --conditions=browser ./src/index.ts serve",
    "build:exe": "bun run script/build.ts --single",
    "build:exe:all": "bun run script/build.ts",
    "preview": "bun run script/release.ts --preview",
    "release": "bun run script/release.ts",
    "typecheck": "tsc --noEmit",
    "check": "tsgo --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:format": "biome format --write",
    "test": "bun test --timeout 90000",
    "test:cov": "bun test --coverage --coverage-reporter=lcov --coverage-dir=./coverage --timeout 90000"
  },
  "exports": {
    "./*": "./src/*"
  },
  "devDependencies": {
    "@effect/language-service": "0.79.0",
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/semver": "^7.5.0",
    "@types/yargs": "17.0.33",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@actions/core": "1.11.1",
    "@actions/github": "6.0.1",
    "@agentclientprotocol/sdk": "0.14.1",
    "@clack/prompts": "1.0.0-alpha.1",
    "@liteai/core": "workspace:*",
    "@liteai/hooks": "workspace:*",
    "@liteai/ink": "workspace:*",
    "@liteai/sdk": "workspace:*",
    "@liteai/util": "workspace:*",
    "@modelcontextprotocol/sdk": "1.25.2",
    "@octokit/graphql": "9.0.2",
    "@octokit/rest": "catalog:",
    "@octokit/webhooks-types": "7.6.1",
    "@opentui/core": "0.1.87",
    "@opentui/solid": "0.1.87",
    "@solid-primitives/event-bus": "1.1.2",
    "@solid-primitives/scheduled": "1.5.2",
    "chalk": "5.6.2",
    "cli-highlight": "2.1.11",
    "clipboardy": "4.0.0",
    "diff": "catalog:",
    "effect": "catalog:",
    "figures": "6.1.0",
    "fuzzysort": "3.1.0",
    "gray-matter": "4.0.3",
    "highlight.js": "11.11.1",
    "hono": "catalog:",
    "immer": "latest",
    "jsonc-parser": "3.3.1",
    "marked": "18.0.2",
    "open": "10.1.2",
    "opentui-spinner": "0.0.6",
    "react": "catalog:",
    "remeda": "catalog:",
    "semver": "^7.6.3",
    "solid-js": "catalog:",
    "strip-ansi": "7.2.0",
    "yargs": "18.0.0",
    "zod": "catalog:",
    "zustand": "latest"
  }
}
