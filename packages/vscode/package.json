{
  "name": "@liteai/vscode",
  "displayName": "liteai",
  "description": "liteai for VS Code",
  "version": "1.2.26",
  "publisher": "sst-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/liteaiagent/liteai"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "liteai-explorer",
          "title": "LiteAI",
          "icon": "images/button-light.svg"
        }
      ]
    },
    "views": {
      "liteai-explorer": [
        {
          "type": "webview",
          "id": "liteai.chatView",
          "name": "Chat",
          "icon": "images/button-light.svg"
        }
      ]
    },
    "configuration": {
      "title": "LiteAI",
      "properties": {
        "liteai.server.url": {
          "type": "string",
          "default": "",
          "description": "URL of a remote LiteAI server. If empty, the extension will bundle and spawn a local liteai-core server."
        },
        "liteai.server.username": {
          "type": "string",
          "default": "",
          "description": "Basic Auth username for remote server connection."
        },
        "liteai.server.password": {
          "type": "string",
          "default": "",
          "description": "Basic Auth password for remote server connection."
        }
      }
    },
    "commands": [
      {
        "command": "liteai.openTerminal",
        "title": "Open liteai",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "liteai.openNewTerminal",
        "title": "Open liteai in new tab",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "liteai.addFilepathToTerminal",
        "title": "Add Filepath to Terminal"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "liteai.openNewTerminal",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "liteai.openTerminal",
        "title": "Run liteai",
        "key": "cmd+escape",
        "mac": "cmd+escape",
        "win": "ctrl+escape",
        "linux": "ctrl+escape"
      },
      {
        "command": "liteai.openNewTerminal",
        "title": "Run liteai",
        "key": "cmd+shift+escape",
        "mac": "cmd+shift+escape",
        "win": "ctrl+shift+escape",
        "linux": "ctrl+shift+escape"
      },
      {
        "command": "liteai.addFilepathToTerminal",
        "title": "liteai: Insert At-Mentioned",
        "key": "cmd+alt+k",
        "mac": "cmd+alt+k",
        "win": "ctrl+alt+K",
        "linux": "ctrl+alt+K"
      }
    ]
  },
  "scripts": {
    "compile-webview": "vite build",
    "compile": "bun run compile-webview && bun run check-types && bun run lint && node esbuild.js",
    "watch:webview": "vite build --watch",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "bun run script/build.ts",
    "build:exe": "bun run --cwd ../core build:exe",
    "test-exe-copy": "bun run script/copy-exe.ts",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/bun": "catalog:",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.94.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3",
    "vite": "8.0.3",
    "vite-plugin-solid": "2.11.11"
  },
  "dependencies": {
    "solid-js": "catalog:",
    "@liteai/ui": "workspace:*"
  }
}
