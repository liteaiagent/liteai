{
  "title": "LiteAI Chat Trace (Langfuse-style)",
  "uid": "liteai-chat-trace-01",
  "schemaVersion": 38,
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "hide": 0,
        "label": "Trace ID (Paste from Logs/Metrics or type '*'",
        "name": "traceId",
        "options": [
          {
            "selected": true,
            "text": "",
            "value": ""
          }
        ],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "panels": [
    {
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "spanBar": {
          "type": "None"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ .trace_id = \"$traceId\" }"
        }
      ],
      "title": "Execution Waterfall (Tool Calls & Latency)",
      "type": "traces"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Ascending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{service_name=\"liteai\"} |= \"$traceId\" | json | line_format \"{{.body}}\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "LLM Conversation Payloads (Prompts & Completions)",
      "type": "logs"
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}
