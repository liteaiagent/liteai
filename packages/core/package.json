{
  "$schema": "https://json.schemastore.org/package.json",
  "version": "1.0.0",
  "name": "@liteai/core",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "bun run --conditions=browser ./src/main.ts --print-logs --port 9000",
    "build": "tsc -b",
    "build:exe": "bun run script/build.ts",
    "db": "bun drizzle-kit",
    "typecheck": "tsc -b",
    "check": "tsgo --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:format": "biome format --write",
    "test": "bun test --timeout 90000",
    "test:cov": "bun test --coverage --coverage-reporter=lcov --coverage-dir=./coverage --timeout 90000"
  },
  "exports": {
    "./*": {
      "types": "./dist/types/*.d.ts",
      "bun": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./parsers-config": "./parsers-config.ts"
  },
  "devDependencies": {
    "@effect/language-service": "0.79.0",
    "@standard-schema/spec": "1.0.0",
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "@types/mime-types": "3.0.1",
    "@types/semver": "^7.5.8",
    "@types/turndown": "5.0.5",
    "@types/yargs": "17.0.33",
    "@types/which": "3.0.4",
    "@typescript/native-preview": "catalog:",
    "drizzle-kit": "1.0.0-beta.16-ea816b6",
    "typescript": "catalog:"
  },
